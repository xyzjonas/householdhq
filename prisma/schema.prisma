// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider     = "mysql"
  relationMode = "prisma"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
}

model Category {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  icon        String?
  color       String?

  transactions Transaction[]
  vehicle      Vehicle?

  @@map("category")
}

model Tag {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  icon        String?
  color       String?

  parentId  Int?
  parentTag Tag?  @relation("TagHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  childTags Tag[] @relation("TagHierarchy")

  transactions Transaction[]

  @@index([parentId])
  @@map("tag")
}

model SourceState {
  id       Int      @id @default(autoincrement())
  created  DateTime @updatedAt
  amount   Float
  sourceId Int
  source   Source   @relation(fields: [sourceId], references: [id])

  @@index([sourceId])
}

model Source {
  id              Int           @id @default(autoincrement())
  name            String
  transactionsIn  Transaction[] @relation(name: "source")
  transactionsOut Transaction[] @relation(name: "target")
  isOut           Boolean       @default(false) // mark 'source' as output (not owned)
  isDisponible    Boolean       @default(false) // mark 'source' as disponible (available to spend)
  isPortfolio     Boolean       @default(false) // mark 'source' as a part of the portfolio
  states          SourceState[]
  color           String?
  position        Int           @default(999) // position in the listing
  type            SourceType    @default(ACCOUNT)
}

enum SourceType {
  OUT
  ACCOUNT
  CASH
  SAVINGS
  INVESTMENT
  DEBT
}

model Transaction {
  id           Int       @id @default(autoincrement())
  created      DateTime  @updatedAt
  transactedAt DateTime?
  description  String
  amount       Float
  currency     String
  cancelled    Boolean   @default(false)
  confirmed    Boolean   @default(true)
  recurring    Int       @default(0) // recurring each n months

  isImportant Boolean @default(false) // mark as an important reminder/tracker
  isHidden    Boolean @default(false) // hide (e.g. internal) transactions

  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id])

  sourceId Int
  source   Source @relation(name: "source", fields: [sourceId], references: [id])

  projectId Int?
  project   Project? @relation(name: "project", fields: [projectId], references: [id])

  targetId Int    @default(2)
  target   Source @relation(name: "target", fields: [targetId], references: [id])

  vehicleId Int?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  fuelEntry    VehicleFuelEntry?    @relation("FuelEntryTransaction")
  serviceEntry VehicleServiceEntry? @relation("ServiceEntryTransaction")

  tags Tag[]

  @@index([sourceId])
  @@index([targetId])
  @@index([categoryId])
  @@index([projectId])
  @@index([vehicleId])
  @@index([isImportant])
  @@fulltext([description])
  @@map("transaction")
}

model Project {
  id          Int      @id @default(autoincrement())
  name        String
  created     DateTime @updatedAt
  description String?
  estimate    Float

  color        String?
  isCompleted  Boolean       @default(false)
  transactions Transaction[] @relation(name: "project")
}

model Meter {
  id      Int          @id @default(autoincrement())
  name    String
  created DateTime     @updatedAt
  unit    String
  icon    String?
  color   String?
  states  MeterState[] @relation(name: "meter")
}

model MeterState {
  id         Int      @id @default(autoincrement())
  value      Float
  meteredAt  DateTime
  meterId    Int
  meter      Meter    @relation(name: "meter", fields: [meterId], references: [id])
  isComputed Boolean  @default(false)

  @@index([meterId])
}

model Vehicle {
  id                  Int       @id @default(autoincrement())
  vin                 String    @unique
  registration        String    @unique
  name                String
  brand               String
  model               String
  color               String?
  icon                String?
  purchasePrice       Float?
  purchasedAt         DateTime?
  mass                Float?
  engineSize          Float?
  fuelType            String?
  maxPower            Float?
  dateOfFabrication   DateTime?
  dateFirstRegistered DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  categoryId Int?      @unique
  category   Category? @relation(fields: [categoryId], references: [id])

  transactions   Transaction[]
  fuelEntries    VehicleFuelEntry[]
  serviceEntries VehicleServiceEntry[]

  @@index([categoryId])
  @@map("vehicle")
}

enum VehicleServiceType {
  REGULAR_MAINTENANCE
  DEFECT
}

model VehicleFuelEntry {
  id         Int      @id @default(autoincrement())
  fueledAt   DateTime
  odometer   Float
  fuelAmount Float
  unitPrice  Float
  isFullTank Boolean  @default(true)

  vehicleId Int
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  transactionId Int
  transaction   Transaction @relation("FuelEntryTransaction", fields: [transactionId], references: [id])

  previousFullTankFuelEntryId Int?
  previousFullTankFuelEntry   VehicleFuelEntry?  @relation("FuelEntryPreviousFullTank", fields: [previousFullTankFuelEntryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  nextFuelEntries             VehicleFuelEntry[] @relation("FuelEntryPreviousFullTank")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([transactionId])
  @@index([vehicleId])
  @@index([fueledAt])
  @@index([previousFullTankFuelEntryId])
  @@map("vehicle_fuel_entry")
}

model VehicleServiceEntry {
  id          Int                @id @default(autoincrement())
  type        VehicleServiceType
  odometer    Float?
  title       String
  servicedAt  DateTime
  description String?

  vehicleId Int
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  transactionId Int
  transaction   Transaction @relation("ServiceEntryTransaction", fields: [transactionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([transactionId])
  @@index([vehicleId])
  @@index([servicedAt])
  @@index([type])
  @@map("vehicle_service_entry")
}

model AppSettings {
  id                          Int      @id @default(1) // Singleton - always ID 1
  currency                    String   @default("USD")
  defaultFuelTransactionTitle String   @default("Fuel")
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@map("app_settings")
}
